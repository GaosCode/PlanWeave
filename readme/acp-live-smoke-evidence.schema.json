{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://planweave.dev/schemas/acp-live-smoke-evidence.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "profile", "agentVersion", "planweaveVersion", "startedAt", "finishedAt", "stages", "checks", "result", "diagnostic"],
  "properties": {
    "version": { "const": "planweave.acp-live-smoke/v2" },
    "profile": { "enum": ["codex-acp", "claude-code-acp", "opencode-acp", "pi-acp"] },
    "agentVersion": { "type": "string", "minLength": 1 },
    "planweaveVersion": { "type": "string", "minLength": 1 },
    "startedAt": { "type": "string", "format": "date-time" },
    "finishedAt": { "type": "string", "format": "date-time" },
    "stages": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact", "cancellation"],
      "properties": {
        "artifact": {
          "type": "object",
          "additionalProperties": false,
          "required": ["sessionId", "reason", "cleanupStatus"],
          "properties": {
            "sessionId": { "type": ["string", "null"], "minLength": 1 },
            "reason": { "enum": ["completed", "failed", "cancelled", "timed_out", null] },
            "cleanupStatus": { "enum": ["succeeded", "failed", null] }
          }
        },
        "cancellation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["sessionId", "reason", "cleanupStatus"],
          "properties": {
            "sessionId": { "type": ["string", "null"], "minLength": 1 },
            "reason": { "enum": ["timed_out", "cancelled", "failed", null] },
            "cleanupStatus": { "enum": ["succeeded", "failed", null] }
          }
        }
      }
    },
    "checks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trusted", "preflight", "session", "streaming", "cancellation", "artifact", "cleanup", "replay"],
      "properties": {
        "trusted": { "type": "boolean" }, "preflight": { "type": "boolean" },
        "session": { "type": "boolean" }, "streaming": { "type": "boolean" },
        "cancellation": { "type": "boolean" }, "artifact": { "type": "boolean" },
        "cleanup": { "type": "boolean" }, "replay": { "type": "boolean" }
      }
    },
    "result": { "enum": ["passed", "failed"] },
    "diagnostic": { "type": ["string", "null"] }
  },
  "allOf": [
    {
      "if": { "properties": { "result": { "const": "passed" } }, "required": ["result"] },
      "then": {
        "type": "object",
        "properties": {
          "checks": {
            "type": "object",
            "properties": {
              "trusted": { "const": true }, "preflight": { "const": true },
              "session": { "const": true }, "streaming": { "const": true },
              "cancellation": { "const": true }, "artifact": { "const": true },
              "cleanup": { "const": true }, "replay": { "const": true }
            }
          },
          "stages": {
            "type": "object",
            "properties": {
              "artifact": {
                "type": "object",
                "properties": {
                  "sessionId": { "type": "string", "minLength": 1 },
                  "reason": { "const": "completed" },
                  "cleanupStatus": { "const": "succeeded" }
                }
              },
              "cancellation": {
                "type": "object",
                "properties": {
                  "sessionId": { "type": "string", "minLength": 1 },
                  "reason": { "enum": ["timed_out", "cancelled"] },
                  "cleanupStatus": { "const": "succeeded" }
                }
              }
            }
          },
          "diagnostic": { "const": null }
        }
      },
      "else": {
        "type": "object",
        "properties": { "diagnostic": { "type": "string", "minLength": 1 } }
      }
    }
  ]
}
